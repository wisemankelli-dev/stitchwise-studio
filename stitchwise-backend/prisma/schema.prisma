generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Core User Model ───────────────────────────────────────────────────────

// Represents a StitchWise user with tier-based access controls.
// tier values: "HOBBYIST", "PRO", "STUDIO"
model User {
  id                   String   @id @default(uuid())
  email                String   @unique
  name                 String
  passwordHash         String
  tier                 String   @default("HOBBYIST")
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  projects              Project[]
  marketplaceListings   MarketplaceListing[] @relation("MarketplaceDesigner")
  collageProjects       CollageProject[]
  quiltBlockProjects    QuiltBlockProject[]
  showcasePhotos        ShowcasePhoto[]
  embroideryPatterns    EmbroideryPattern[]
}

// ─── Project Inquiry ───────────────────────────────────────────────────────

// status values: "PENDING", "REVIEWING", "APPROVED", "REJECTED"
model ProjectInquiry {
  id          String   @id @default(uuid())
  name        String
  email       String
  description String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Solo Designer Project Model ───────────────────────────────────────────

// Represents a personal design project owned by a single user.
// The `data` field stores SVG paths and pattern state as JSON.
// visibility values: "PRIVATE" (default, user's own project),
// "PUBLIC" (anyone can view), "SAMPLE" (curated sample design)
model Project {
  id         String   @id @default(uuid())
  name       String
  data       String   @default("{}")
  userId     String
  visibility String   @default("PRIVATE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Marketplace Models ────────────────────────────────────────────────────

// Represents a pattern listing in the Designer Marketplace.
// visibility values: "PUBLIC", "PRIVATE", "UNLISTED"
model MarketplaceListing {
  id          String   @id @default(uuid())
  designerId  String
  name        String
  description String   @default("")
  price       Int      @default(0) // Price in cents ($0 = free)
  visibility  String   @default("PUBLIC")
  tags        String   @default("[]") // JSON array of tag strings
  stitchFile  String?  // URL/path to the .dst/.pes file
  thumbnail   String?  // URL/path to preview image
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  designer User @relation("MarketplaceDesigner", fields: [designerId], references: [id], onDelete: Cascade)
}

// ─── Community Showcase Model ─────────────────────────────────────────────

// Represents a photo uploaded by a user to the Community Showcase gallery.
// status values: "PENDING" (awaiting review), "APPROVED" (visible in gallery),
// "REJECTED" (rejected during moderation)
model ShowcasePhoto {
  id           String   @id @default(uuid())
  userId       String
  projectId    String?  // Optional link to the finished design project
  title        String
  caption      String?
  imageUrl     String   // URL to the stored image
  thumbnailUrl String?  // URL to a smaller thumbnail version
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Collage Studio Models ─────────────────────────────────────────────────

// Stores collage quilting projects with a JSON data column (Option A from research).
// The `data` field holds the full canvas state: layers, fabrics, shapes, stitches.
// This keeps the schema simple for MVP while allowing future migration to normalized tables.
model CollageProject {
  id        String   @id @default(uuid())
  name      String
  userId    String
  data      String   @default("{}") // JSON: full canvas state (layers, fabrics, shapes, stitches)
  width     Float    @default(300)   // canvas width in mm
  height    Float    @default(300)   // canvas height in mm
  thumbnail String?                  // URL to preview image
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Quilt Block Studio Models ────────────────────────────────────────────────

// Stores quilt block design projects with JSON data column (same pattern as CollageProject).
// The `data` field holds the full block state: grid dimensions, patches (geometric
// shapes), fabric references, layout, and color palette.
model QuiltBlockProject {
  id        String   @id @default(uuid())
  name      String
  userId    String
  data      String   @default("{}") // JSON: grid, patches, fabrics, layout, palette
  blockSize Float    @default(12)   // Finished block size in inches (6-48 typical)
  gridRows  Int      @default(4)    // Grid rows (e.g. 4 for a 4x4 block)
  gridCols  Int      @default(4)    // Grid columns
  thumbnail String?                 // URL to preview image
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Embroidery Pattern Model ───────────────────────────────────────────────

// Stores generated embroidery patterns with full grid data.
// gridData and dmcPalette are JSON strings for flexible storage.
// visibility values: "PRIVATE" (default), "PUBLIC", "UNLISTED"
model EmbroideryPattern {
  id          String   @id @default(uuid())
  name        String
  userId      String
  gridData    String   // JSON string of StitchCell[][]
  gridSize    Int      // grid dimension (50, 75, 100, 150, 200)
  dmcPalette  String   // JSON string of DmcUsage[]
  stitchCount Int      // total stitches
  previewUrl  String?  // optional preview image URL
  prompt      String?  // original text prompt (if AI-generated)
  sourceImage String?  // URL of original uploaded image
  visibility  String   @default("PRIVATE") // PRIVATE, PUBLIC, UNLISTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
