generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Core User Model ───────────────────────────────────────────────────────

// Represents a StitchWise user with tier-based access controls.
// tier values: "HOBBYIST", "PRO", "STUDIO"
model User {
  id                   String   @id @default(uuid())
  email                String   @unique
  name                 String
  passwordHash         String
  tier                 String   @default("HOBBYIST")
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  projects Project[]
}

// ─── Project Inquiry ───────────────────────────────────────────────────────

// status values: "PENDING", "REVIEWING", "APPROVED", "REJECTED"
model ProjectInquiry {
  id          String   @id @default(uuid())
  name        String
  email       String
  description String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Collaborative Workshop Models ─────────────────────────────────────────

// Represents a design project within the Collaborative Workshop.
// The `data` field stores SVG paths and pattern state as JSON.
model Project {
  id        String   @id @default(uuid())
  name      String
  data      String   @default("{}")
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  shares        ProjectShare[]
  collaborators ProjectCollaborator[]
}

// Tracks sharing links for read-only or read-write access to a project.
// permission values: "VIEWER", "EDITOR"
model ProjectShare {
  id            String   @id @default(uuid())
  projectId     String
  token         String   @unique
  permission    String   @default("VIEWER")
  isActive      Boolean  @default(true)
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// Tracks collaborators explicitly invited via email to a project.
// permission values: "VIEWER", "EDITOR"
model ProjectCollaborator {
  id            String   @id @default(uuid())
  projectId     String
  email         String
  permission    String   @default("EDITOR")
  acceptedAt    DateTime?
  invitedAt     DateTime @default(now())

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, email])
}

// ─── Marketplace Models ────────────────────────────────────────────────────

// Represents a pattern listing in the Designer Marketplace.
// visibility values: "PUBLIC", "PRIVATE", "UNLISTED"
model MarketplaceListing {
  id          String   @id @default(uuid())
  designerId  String
  name        String
  description String   @default("")
  price       Int      @default(0) // Price in cents ($0 = free)
  visibility  String   @default("PUBLIC")
  tags        String   @default("[]") // JSON array of tag strings
  stitchFile  String?  // URL/path to the .dst/.pes file
  thumbnail   String?  // URL/path to preview image
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  designer User @relation(fields: [designerId], references: [id], onDelete: Cascade)
}